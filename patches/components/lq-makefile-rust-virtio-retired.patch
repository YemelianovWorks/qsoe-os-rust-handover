diff --git a/Makefile b/Makefile
--- a/Makefile
+++ b/Makefile
@@ -116,6 +116,7 @@ MODPKG_CPIO   := $(QUSER)/build/modpkg.cpio
 export MODPKG_CPIO
 SELECTED_SLOGGER_ELF ?= $(abspath $(TOP)/..)/build/rust/selected/sbin/slogger.elf
 SELECTED_PIPE_ELF ?= $(abspath $(TOP)/..)/build/rust/selected/sbin/pipe.elf
+SELECTED_VIRTIO_ELF ?= $(abspath $(TOP)/..)/build/rust/selected/sbin/devb-virtio.elf
 
 # taskman.elf is board-independent (the seL4 API it builds against is the
 # same on every platform) and therefore built once and shared.
@@ -603,12 +604,16 @@ $(MODPKG_CPIO): $(LIBC_SO) $(LIBC_CRT0) $(RTLD_SO)
 	+$(MAKE) -C $(abspath $(TOP)/..) pipe-artifact \
 	    LIBC_SO=$(LIBC_SO) \
 	    SELECTED_PIPE_ELF=$(SELECTED_PIPE_ELF)
+	+$(MAKE) -C $(abspath $(TOP)/..) virtio-artifact \
+	    LIBC_SO=$(LIBC_SO) \
+	    SELECTED_VIRTIO_ELF=$(SELECTED_VIRTIO_ELF)
 	+$(MAKE) -C $(QUSER) cpio \
 	    LIBC_SO=$(LIBC_SO) \
 	    RTLD_SO=$(RTLD_SO) \
 	    DYNLIBC_SO=$(LIBC_SO) \
 	    SBIN_SLOG_ELF=$(SELECTED_SLOGGER_ELF) \
-	    SBIN_PIPE_ELF=$(SELECTED_PIPE_ELF)
+	    SBIN_PIPE_ELF=$(SELECTED_PIPE_ELF) \
+	    SBIN_VIRTIO_ELF=$(SELECTED_VIRTIO_ELF)
 
 clean:
 	rm -rf $(BUILD)
