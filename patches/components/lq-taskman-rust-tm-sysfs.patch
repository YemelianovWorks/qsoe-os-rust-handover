diff --git a/taskman/Makefile b/taskman/Makefile
--- a/taskman/Makefile
+++ b/taskman/Makefile
@@ -43,9 +43,10 @@
 QSOE_RUST_TM_PROCFS ?= 0
 QSOE_RUST_TM_CRED ?= 0
 QSOE_RUST_TM_PSEUDODEV ?= 0
+QSOE_RUST_TM_SYSFS ?= 0
 
-TM_RUST_PROVIDER_COUNT := $(words $(filter 1,$(QSOE_RUST_TM_CRED) $(QSOE_RUST_TM_PROCFS) $(QSOE_RUST_TM_PSEUDODEV)))
-ifneq ($(filter 2 3,$(TM_RUST_PROVIDER_COUNT)),)
+TM_RUST_PROVIDER_COUNT := $(words $(filter 1,$(QSOE_RUST_TM_CRED) $(QSOE_RUST_TM_PROCFS) $(QSOE_RUST_TM_PSEUDODEV) $(QSOE_RUST_TM_SYSFS)))
+ifneq ($(filter 2 3 4,$(TM_RUST_PROVIDER_COUNT)),)
 $(error select at most one taskman Rust provider until they share one staticlib)
 endif
 
@@ -89,6 +90,7 @@
 RUST_TM_PROCFS_A := $(REPO_ROOT)/build/rust/tm-procfs/libqsoe_tm_procfs.a
 RUST_TM_CRED_A := $(REPO_ROOT)/build/rust/tm-cred/libqsoe_tm_cred.a
