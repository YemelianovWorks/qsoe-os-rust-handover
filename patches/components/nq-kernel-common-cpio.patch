             PANIC("initrd: taskman.bin not found");
 
         /* /chosen/bootargs is taskman's command line (the kernel
@@ -367,4 +370,4 @@ static void kmain_primary_pa(void)
         sk_debug_level = parse_debug_level(strs->bootargs,
