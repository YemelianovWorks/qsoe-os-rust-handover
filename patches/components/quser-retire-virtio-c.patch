-# driver used by QSOE/L under QEMU (no NVMe there: seL4 has no AIA).
-#
-# Serves /dev/vblk0 raw (no GPT) on the QSOE resource-server framework
-# (libressrv); the disk carries a qrvfs image that fs-qrv mounts.
-#
-# Copyright (c) 2026 Yuri Zaporozhets <yuriz@qsoe.net>
-# SPDX-License-Identifier: Apache-2.0
-
-include ../../common.mk
-
-PROGRAM := devb-virtio
-SRCS    := main.c virtio_blk.c
-
-EXTRA_CFLAGS := -I$(QUSER)/ressrv/include
-
